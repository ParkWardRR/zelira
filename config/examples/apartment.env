# Example: Apartment / Small Network
# For a simple setup with one router, no VLANs, 10-20 devices.
# Typical for apartments, studios, or small homes.

ZELIRA_IP=192.168.1.2
ZELIRA_GATEWAY=192.168.1.1
ZELIRA_SUBNET=192.168.1.0/24
ZELIRA_POOL_START=192.168.1.100
ZELIRA_POOL_END=192.168.1.250
ZELIRA_DOMAIN=home.local
ZELIRA_INTERFACE=eth0
ZELIRA_TZ=America/New_York
ZELIRA_PIHOLE_PASSWORD=changeme
