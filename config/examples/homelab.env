# Example: Homelab with VLANs
# For a homelab with managed switches, VLANs, multiple subnets, 40+ devices.
# This is close to the Alpina network that Zelira was extracted from.
#
# Architecture:
#   - Zelira host on management/infrastructure VLAN
#   - Kea serves DHCP for the main user VLAN
#   - Unbound resolves for all VLANs (clients point DNS here)
#   - Chrony NTP for all switches, APs, and servers
#   - Caddy with DNS-01 TLS for LAN-only HTTPS
#
# VLAN layout (example):
#   VLAN 1   - Management     172.16.1.0/24
#   VLAN 3   - Servers/NAS    172.16.3.0/24
#   VLAN 6   - Infrastructure 172.16.6.0/24
#   VLAN 200 - DHCP pool      172.16.200.0/24

# ─── Network ───────────────────────────────────────────
ZELIRA_IP=172.16.1.69
ZELIRA_GATEWAY=172.16.1.1
ZELIRA_SUBNET=172.16.0.0/16
ZELIRA_POOL_START=172.16.200.100
ZELIRA_POOL_END=172.16.200.250
ZELIRA_DOMAIN=home.lab
ZELIRA_INTERFACE=eth0
ZELIRA_TZ=America/Los_Angeles
ZELIRA_PIHOLE_PASSWORD=changeme
ZELIRA_FALLBACK_DNS=1.1.1.1

# ─── Add-on: Dynamic DNS (Namecheap) ──────────────────
ZELIRA_DDNS_PROVIDER=namecheap
ZELIRA_DDNS_HOST=home
ZELIRA_DDNS_DOMAIN=yourdomain.com
ZELIRA_DDNS_PASSWORD=your-ddns-password-here
ZELIRA_DDNS_INTERVAL=300

# ─── Add-on: Dashboard (Caddy with TLS) ───────────────
ZELIRA_DASH_DOMAIN=home.yourdomain.com
ZELIRA_DNS_DOMAIN=dns.yourdomain.com
