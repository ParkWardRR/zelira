# Example: House / Medium Network
# For a typical house with multiple APs, smart home devices, 20-50 clients.
# Uses a /23 subnet for more address space and includes NTP + DDNS add-ons.

# ─── Network ───────────────────────────────────────────
ZELIRA_IP=10.0.0.2
ZELIRA_GATEWAY=10.0.0.1
ZELIRA_SUBNET=10.0.0.0/23
ZELIRA_POOL_START=10.0.1.1
ZELIRA_POOL_END=10.0.1.250
ZELIRA_DOMAIN=house.local
ZELIRA_INTERFACE=eth0
ZELIRA_TZ=America/Chicago
ZELIRA_PIHOLE_PASSWORD=changeme

# ─── Add-on: Dynamic DNS ──────────────────────────────
ZELIRA_DDNS_PROVIDER=cloudflare
ZELIRA_DDNS_API_KEY=your-cloudflare-api-token
ZELIRA_DDNS_ZONE=yourdomain.com
ZELIRA_DDNS_SUBDOMAIN=home

# ─── Add-on: Dashboard ────────────────────────────────
ZELIRA_DASH_PORT=8083
