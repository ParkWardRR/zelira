# Zelira — Network Settings
# Copy this file to .env and edit for your network
#
#   cp env.example .env
#   vi .env
#
# All values are required unless marked optional.

# ─── Network ───────────────────────────────────────────
# Static IP of THIS host (the DNS/DHCP server)
ZELIRA_IP=192.168.1.2

# Your router/gateway IP
ZELIRA_GATEWAY=192.168.1.1

# LAN subnet in CIDR notation
ZELIRA_SUBNET=192.168.1.0/24

# DHCP pool range (Kea hands out IPs from this range)
ZELIRA_POOL_START=192.168.1.100
ZELIRA_POOL_END=192.168.1.250

# Domain name for local DNS
ZELIRA_DOMAIN=home.local

# Network interface Kea listens on
ZELIRA_INTERFACE=eth0

# ─── General ───────────────────────────────────────────
# Timezone (used by Pi-hole container)
ZELIRA_TZ=America/New_York

# Pi-hole web UI password
ZELIRA_PIHOLE_PASSWORD=changeme

# ─── Optional ─────────────────────────────────────────
# DNS fallback (used only during initial Pi-hole startup)
# ZELIRA_FALLBACK_DNS=1.1.1.1

# ─── Add-on: NTP (Chrony) ─────────────────────────────
# Runs: sudo ./scripts/deploy-ntp.sh
# Uses ZELIRA_SUBNET for client access (allow directive)
# Uses ZELIRA_IP for Kea DHCP Option 42 injection

# ─── Add-on: Dynamic DNS ──────────────────────────────
# Runs: sudo ./scripts/deploy-ddns.sh
# Uncomment and fill in for your provider:

# ZELIRA_DDNS_PROVIDER=namecheap
# ZELIRA_DDNS_HOST=home
# ZELIRA_DDNS_DOMAIN=yourdomain.com
# ZELIRA_DDNS_PASSWORD=your-ddns-password-here
# ZELIRA_DDNS_INTERVAL=300

# Cloudflare:
# ZELIRA_DDNS_PROVIDER=cloudflare
# ZELIRA_DDNS_API_KEY=your-cloudflare-api-token
# ZELIRA_DDNS_ZONE=yourdomain.com
# ZELIRA_DDNS_SUBDOMAIN=home

# DuckDNS:
# ZELIRA_DDNS_PROVIDER=duckdns
# ZELIRA_DDNS_TOKEN=your-duckdns-token
# ZELIRA_DDNS_SUBDOMAINS=yoursubdomain

# ─── Add-on: Dashboard (Caddy) ────────────────────────
# Runs: sudo ./scripts/deploy-dashboard.sh
# If domains are set, Caddy uses auto-TLS (DNS challenge).
# If blank, Caddy serves on ZELIRA_DASH_PORT (HTTP, no TLS).

# ZELIRA_DASH_DOMAIN=home.yourdomain.com
# ZELIRA_DNS_DOMAIN=dns.yourdomain.com
# ZELIRA_DASH_PORT=8083
